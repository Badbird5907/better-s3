{
  "name": "@silo/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./services": "./src/service/index.ts"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@silo/auth": "workspace:*",
    "@silo/db": "workspace:*",
    "@silo/redis": "workspace:*",
    "@silo/shared": "workspace:*",
    "@silo/types": "workspace:*",
    "@silo/validators": "workspace:*",
    "@t3-oss/env-core": "^0.13.10",
    "@trpc/server": "catalog:",
    "@upstash/redis": "^1.36.1",
    "@vercel/queue": "^0.1.3",
    "drizzle-orm": "^0.44.7",
    "nanoid": "^5.1.6",
    "superjson": "2.2.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@silo/eslint-config": "workspace:*",
    "@silo/prettier-config": "workspace:*",
    "@silo/tsconfig": "workspace:*",
    "@types/react": "catalog:react19",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@silo/prettier-config"
}
